# ========== 应用 ==========
APP_PORT=8080
LOG_LEVEL=info
AUTO_SEED=true
AUTO_SEED_DEMO=false
RUN_FAIL_RATE=0.25
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ========== JWT（生产环境必须修改！）==========
JWT_SECRET=change-me-to-a-random-32-byte-string

# ========== 数据库 ==========
# 说明：默认 docker-compose 会把容器内的 DB_HOST 强制注入为 "mysql"，
# 这里的 127.0.0.1 仅供「非容器化直接 go run ./cmd/server」场景使用.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=testpilot
DB_PASSWORD=testpilot
DB_NAME=testpilot
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=60
DB_CONNECT_RETRIES=20
DB_RETRY_DELAY_SEC=2

# ========== Redis ==========
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== Docker Compose 端口 ==========
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT=3306
REDIS_PORT=6379
