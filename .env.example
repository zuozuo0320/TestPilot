APP_PORT=8080
LOG_LEVEL=info

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=testpilot
DB_PASSWORD=testpilot
DB_NAME=testpilot
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=60
DB_CONNECT_RETRIES=20
DB_RETRY_DELAY_SEC=2

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

AUTO_SEED=true
RUN_FAIL_RATE=0.25
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
SQLITE_PATH=./testpilot_demo.db

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT=3306
REDIS_PORT=6379
